<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude gRPC/Protobuf generated code -->
    <Match>
        <Source name="~.*Grpc\.java"/>
    </Match>
    <Match>
        <Source name="~.*OrBuilder\.java"/>
    </Match>
    <!-- Exclude classes generated by annotation processors and Quarkus -->
    <Match>
        <Class name="~.*_Bean"/>
    </Match>
    <Match>
        <Class name="~.*_ClientProxy"/>
    </Match>
    <Match>
        <Class name="~.*_Subclass"/>
    </Match>
    <Match>
        <Class name="~.*_Observer.*"/>
    </Match>
</FindBugsFilter>
